// TopDeck Live – Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Raw webhook event log ───────────────────────────────────────────────────

model WebhookEvent {
  id         String   @id // event.id (dedup key)
  tid        String? // null for ping events
  type       String // e.g. "round.started"
  apiVersion String
  createdAt  DateTime // event.created (unix ms → DateTime)
  receivedAt DateTime @default(now())
  rawPayload String // full JSON blob

  @@index([tid])
  @@index([type])
  @@index([createdAt])
}

// ─── Derived tournament state (one row per tournament) ──────────────────────

model TournamentState {
  tid String @id

  // Tournament metadata
  name   String @default("")
  game   String @default("")
  format String @default("")

  // Enriched by REST API (null until fetched via resync)
  startDate   String? // unix ms as string
  status      String  @default("Not Started") // "Not Started"|"Ongoing"|"Complete"
  location    String? // JSON: TopDeckLocation
  headerImage String?

  // Stage / round
  currentStage     Int     @default(0)
  currentRound     Int     @default(0)
  roundLabel       String  @default("")
  roundStatus      String  @default("pending") // "pending"|"active"|"ended"
  roundStartedAt   String? // unix ms as string (null until round.started)
  roundTimeMinutes Int? // null if no timer configured

  // Live data blobs (stored as JSON strings, typed in application layer)
  tables          String @default("[]") // TopDeckTable[]
  matchResults    String @default("[]") // MatchResultEntry[]
  standings       String @default("[]") // TopDeckStanding[]
  players         String @default("[]") // TopDeckPlayer[]
  droppedPlayers  String @default("[]") // DroppedPlayerEntry[]
  waitlistPlayers String @default("[]") // TopDeckAttendee[] (REST API only)
  roundHistory    String @default("[]") // RoundSnapshot[]

  // Check-in
  checkinStarted Boolean @default(false)
  checkinStage   Int?

  // Finish state
  finished         Boolean @default(false)
  finishedAt       String? // unix ms as string
  winnerData       String? // JSON: TopDeckPlayer
  participantCount Int?

  // Event tracking — for conflict resolution
  lastEventId      String @default("")
  lastEventCreated String @default("0") // unix ms as string

  updatedAt DateTime @updatedAt

  @@index([finished])
  @@index([status])
}

// ─── Parking cache (one row per unique venue location) ──────────────────────
//
// Results from the parking provider are cached here to avoid hitting
// external APIs on every page load. The cache key is derived from the
// venue lat/lng rounded to 4 decimal places (~11 m precision).
//
// TTL is enforced at the application layer by comparing expiresAt to now().
// Expired rows are overwritten in-place on the next cache miss.

model ParkingCache {
  id String @id @default(cuid())

  /// Stable key: "lat4dp:lng4dp"  e.g. "51.5074:-0.1278"
  cacheKey String @unique

  lat Float
  lng Float

  /// "overpass" | "google_places"
  provider String

  /// JSON: ParkingResult[]
  results String

  fetchedAt DateTime
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

// ─── Discord channel linked to a tournament ─────────────────────────────────
//
// Created via the /topdeck link <tid> slash command.
// One row per tournament — a tournament can only be linked to one channel
// at a time (the channel that ran the link command).
//
// settings is a JSON blob holding DiscordTournamentSettings.

model DiscordLink {
  id String @id @default(cuid())

  /// TopDeck tournament ID
  tid String @unique

  /// Discord snowflake IDs
  guildId   String
  channelId String

  /// JSON: DiscordTournamentSettings
  settings String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId])
  @@index([channelId])
}

// ─── Event operations tools ─────────────────────────────────────────────────
//
// These tables power the on-the-day organizer workflows that are not part of
// TopDeck's event stream: public announcements, judge/help queue, and a simple
// venue floor map that can be edited from the dashboard and shown to players.

model TournamentAnnouncement {
  id String @id @default(cuid())

  tid      String
  title    String
  body     String
  tone     String  @default("info") // "info" | "success" | "warning" | "urgent"
  audience String  @default("all") // "all" | "players" | "venue" | "discord"
  pinned   Boolean @default(true)

  publishedToDiscordAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tid, createdAt])
  @@index([tid, pinned])
}

model JudgeCall {
  id String @id @default(cuid())

  tid         String
  tableNumber String?
  playerName  String?
  message     String?
  status      String  @default("open") // "open" | "acknowledged" | "resolved"
  category    String  @default("rules") // "rules" | "deck_check" | "missing_player" | "result_issue" | "logistics" | "other"
  priority    String  @default("normal") // "low" | "normal" | "high" | "urgent"
  assignedTo  String?
  internalNote String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  @@index([tid, status])
  @@index([tid, priority])
  @@index([tid, createdAt])
}

model TournamentFloorMap {
  tid String @id

  title String @default("Venue floor map")
  zones String @default("[]") // JSON: FloorMapZone[]
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
