# ─── Database ───────────────────────────────────────────────────────────────
# SQLite file path (relative to project root).
# For production (Vercel / serverless) use Turso or Postgres — SQLite does not
# persist across deployments. See README → Deploying to Vercel.
DATABASE_URL="file:./dev.db"

# ─── TopDeck.gg webhook secret ──────────────────────────────────────────────
# Copy from: TopDeck developer portal → Endpoints → your endpoint → Secret
# Starts with whsec_
TOPDECK_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ─── TopDeck.gg REST API key ─────────────────────────────────────────────────
# Copy from: https://topdeck.gg/developers
# Required for: tournament enrichment (startDate, location, header image),
#               player details, and the attendees (waitlist) endpoint.
TOPDECK_API_KEY="YOUR_API_KEY_HERE"

# ─── Base URL ────────────────────────────────────────────────────────────────
# Used by the local test script to know where to POST events.
# In production set this to your Vercel domain (https://your-app.vercel.app).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Optional organizer/admin token.
# When set, dashboard/producer pages and mutating tournament APIs require
# ?admin=<token>, a topdeck_admin cookie, or x-topdeck-admin-token.
TOPDECK_ADMIN_TOKEN=""

# ─── Parking ─────────────────────────────────────────────────────────────────
# Which parking data provider to use.
# Options:
#   "overpass"      — free, no key needed; uses OpenStreetMap / Overpass API (default)
#   "google_places" — requires GOOGLE_MAPS_API_KEY; better hours + ratings data
PARKING_PROVIDER="overpass"

# Google Maps / Places API key.
# Only required when PARKING_PROVIDER="google_places".
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New). Geocoding API is handled by Nominatim (free) unless
# you want to swap it out.
# Leave blank (or omit) if using the default Overpass/OSM provider.
GOOGLE_MAPS_API_KEY=""

# ─── Discord bot ─────────────────────────────────────────────────────────────
# All Discord variables are optional. Leave all blank to disable Discord features.
# See README → Discord bot for a full setup walkthrough.

# Bot token — Discord Developer Portal → your app → Bot → Token
# NEVER commit this value. NEVER log it.
DISCORD_BOT_TOKEN=""

# Application (client) ID — Discord Developer Portal → your app → General Information
DISCORD_CLIENT_ID=""

# Application public key — Discord Developer Portal → your app → General Information
# Used to verify Ed25519 signatures on incoming interaction requests.
# Required once you set an Interactions Endpoint URL in the portal.
DISCORD_PUBLIC_KEY=""

# Guild (server) ID — enables instant slash-command registration during local dev.
# Right-click your server icon in Discord (Developer Mode on) → Copy Server ID.
# Leave blank in production — commands will be registered globally (~1 hr propagation).
DISCORD_GUILD_ID=""
